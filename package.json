{
  "name": "haml-all",
  "displayName": "HAML - All in One",
  "description": "Including syntax highlighting, linting, formatting, and additional features.",
  "version": "3.1.0",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#EAEAE1",
    "theme": "light"
  },
  "publisher": "wilfison",
  "author": {
    "name": "wilfison",
    "url": "https://github.com/wilfison"
  },
  "repository": {
    "url": "https://github.com/wilfison/vscode-haml-all"
  },
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "tags": [
    "haml",
    "ruby",
    "lint",
    "linter",
    "snippets"
  ],
  "keywords": [
    "haml",
    "ruby",
    "lint",
    "linter",
    "snippets"
  ],
  "recommendations": [
    "wilfison.one-dark-dracula",
    "Shopify.ruby-lsp"
  ],
  "license": "MIT",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Runs the project's Ruby tooling (haml-lint, RuboCop, Rails), which can execute code from project files (e.g. a `require:` directive in .haml-lint.yml). Trust the workspace before relying on linting or formatting."
    }
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Haml All in One - Linter",
      "properties": {
        "hamlAll.lintEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable haml-lint"
        },
        "hamlAll.linterExecutablePath": {
          "type": "string",
          "default": "haml-lint",
          "scope": "machine",
          "description": "Path to haml-lint executable. Machine-scoped for security: it cannot be set by a workspace's .vscode/settings.json, only in your user settings."
        },
        "hamlAll.useBundler": {
          "type": "boolean",
          "default": false,
          "description": "Use `bundle exec` to run haml-lint. (If this is true, the 'linterExecutablePath' setting is ignored.)"
        },
        "railsRoutes.railsCommand": {
          "type": "string",
          "default": "bin/rails",
          "scope": "machine",
          "description": "Command used to run Rails (e.g. for project detection and routes). Machine-scoped for security: it cannot be set by a workspace's .vscode/settings.json, only in your user settings."
        }
      }
    },
    "commands": [
      {
        "command": "hamlAll.createPartialFromSelection",
        "title": "HAML: Create a partial from selection",
        "enablement": "editorLangId == haml"
      },
      {
        "command": "hamlAll.html2Haml",
        "title": "HAML: Convert HTML to HAML",
        "enablement": "editorLangId =~ /html|erb|haml/"
      },
      {
        "command": "hamlAll.wrapInConditional",
        "title": "HAML: Wrap in conditional",
        "enablement": "editorLangId == haml"
      },
      {
        "command": "hamlAll.wrapInBlock",
        "title": "HAML: Wrap in a ruby block",
        "enablement": "editorLangId == haml"
      }
    ],
    "languages": [
      {
        "id": "haml",
        "aliases": [
          "Ruby Haml",
          "Haml",
          "haml"
        ],
        "extensions": [
          ".haml"
        ],
        "configuration": "./haml-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "haml",
        "scopeName": "text.haml",
        "path": "./syntaxes/haml.json"
      }
    ],
    "snippets": [
      {
        "language": "haml",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "haml",
        "path": "./snippets/rails-snippets.json"
      },
      {
        "language": "ruby",
        "path": "./snippets/test-snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p ./",
    "watch-tests": "tsc -w -p ./",
    "pretest": "npm run compile-tests && npm run compile",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test",
    "package": "vsce package",
    "format": "prettier --write \"src/**/*.ts\" \"*.mjs\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.mjs\" \"*.json\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.63.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
